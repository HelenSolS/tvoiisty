# Скопируй на сервере: cp env.server.example .env и заполни значения.
# Файл .env в git не коммитить. Реальные ключи — только в .env, не сюда.

# --- Обязательно (Postgres) ---
# PGHOST=postgres — только внутри Docker (имя контейнера). На Mac для локальных тестов ставь PGHOST=localhost.
PGHOST=postgres
PGPORT=5432
PGUSER=tvoiisty
PGPASSWORD=
PGDATABASE=tvoiisty_db

# --- Обязательно (JWT) ---
JWT_SECRET=

# --- Обязательно (KIE) ---
KIE_API_KEY=

# --- Хранилище (один из вариантов) ---
BLOB_READ_WRITE_TOKEN=
# SUPABASE_URL=
# SUPABASE_SERVICE_KEY=
# SUPABASE_BUCKET=media

# --- Примерка и видео ---
FAL_KEY=

